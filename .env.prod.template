# SnapLearn AI - Production Environment Configuration
# Phase 5 - Production Environment Template

# ==============================================================================
# CORE APPLICATION SETTINGS
# ==============================================================================

# Application Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
VERSION=5.0.0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
MAX_WORKERS=4

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================

# JWT Authentication (REQUIRED - Generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_this_in_production

# API Security
API_KEY_SALT=your_api_key_salt_here
WEBHOOK_SECRET=your_webhook_secret_here

# CORS Configuration
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://demo.snaplearn.ai

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=snaplearn
POSTGRES_USER=snaplearn_user
POSTGRES_PASSWORD=secure_database_password_change_this
DATABASE_URL=postgresql://snaplearn_user:secure_database_password_change_this@postgres:5432/snaplearn

# Redis Cache and Sessions
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=optional_redis_password

# ==============================================================================
# AI SERVICES CONFIGURATION
# ==============================================================================

# Google Gemini API (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative AI Providers (Optional)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==============================================================================
# EXTERNAL SERVICES
# ==============================================================================

# Supabase (Optional - for enhanced data storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Email Service (Optional - for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ==============================================================================
# CLOUD STORAGE & CDN
# ==============================================================================

# AWS S3 (for video/image storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=snaplearn-media-production

# CloudFlare (Optional - for CDN)
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ==============================================================================
# MONITORING & OBSERVABILITY
# ==============================================================================

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=production

# Grafana
GRAFANA_ADMIN_PASSWORD=secure_grafana_password

# Prometheus
PROMETHEUS_RETENTION=30d

# ==============================================================================
# BACKUP CONFIGURATION
# ==============================================================================

# Backup Schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC

# S3 Backup Storage
BACKUP_S3_BUCKET=snaplearn-backups-production
BACKUP_RETENTION_DAYS=30

# ==============================================================================
# FEATURE FLAGS & LIMITS
# ==============================================================================

# Rate Limiting
API_RATE_LIMIT=10000  # requests per hour per IP
WEBHOOK_RATE_LIMIT=1000  # webhooks per hour per org

# Resource Limits
MAX_VIDEO_DURATION=600  # seconds
MAX_FILE_SIZE=50MB
MAX_CONCURRENT_VIDEOS=5

# Feature Toggles
ENABLE_DEMO_PORTAL=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_WEBHOOK_SYSTEM=true
ENABLE_MULTI_TENANT=true
ENABLE_VIDEO_GENERATION=true

# ==============================================================================
# SSL/TLS CONFIGURATION
# ==============================================================================

# SSL Certificates (if using HTTPS)
SSL_CERT_PATH=/etc/ssl/certs/snaplearn.crt
SSL_KEY_PATH=/etc/ssl/private/snaplearn.key

# Let's Encrypt (if using automatic SSL)
LETSENCRYPT_EMAIL=admin@yourdomain.com
LETSENCRYPT_HOST=yourdomain.com,www.yourdomain.com

# ==============================================================================
# DOMAIN CONFIGURATION
# ==============================================================================

# Primary Domain
DOMAIN_NAME=yourdomain.com
API_DOMAIN=api.yourdomain.com
FRONTEND_DOMAIN=yourdomain.com

# Subdomain Configuration
DEMO_DOMAIN=demo.yourdomain.com
MONITORING_DOMAIN=monitoring.yourdomain.com
DOCS_DOMAIN=docs.yourdomain.com

# ==============================================================================
# DEVELOPMENT OVERRIDES (Remove in production)
# ==============================================================================

# Development settings (comment out or remove for production)
# SKIP_MIGRATIONS=false
# ENABLE_DEBUG_TOOLBAR=false
# MOCK_AI_RESPONSES=false

# ==============================================================================
# ORGANIZATION DEFAULTS
# ==============================================================================

# Default organization settings for new signups
DEFAULT_ORG_PLAN=basic
DEFAULT_ORG_FEATURES=ai_tutoring,multimodal_input,basic_analytics
DEFAULT_MAX_STUDENTS=100
DEFAULT_MAX_EDUCATORS=5

# ==============================================================================
# INTEGRATION DEFAULTS
# ==============================================================================

# Default integration settings
DEFAULT_WEBHOOK_TIMEOUT=30
DEFAULT_WEBHOOK_RETRIES=3
DEFAULT_API_KEY_EXPIRY_DAYS=365

# ==============================================================================
# USAGE QUOTAS
# ==============================================================================

# Default usage quotas per organization plan
FREE_PLAN_API_CALLS=1000
BASIC_PLAN_API_CALLS=10000
PRO_PLAN_API_CALLS=100000
ENTERPRISE_PLAN_API_CALLS=1000000

FREE_PLAN_VIDEO_MINUTES=60
BASIC_PLAN_VIDEO_MINUTES=600
PRO_PLAN_VIDEO_MINUTES=3600
ENTERPRISE_PLAN_VIDEO_MINUTES=18000

# ==============================================================================
# DEPLOYMENT METADATA
# ==============================================================================

# Deployment information (automatically set by CI/CD)
BUILD_DATE=${BUILD_DATE:-$(date -u +'%Y-%m-%dT%H:%M:%SZ')}
GIT_COMMIT=${GIT_COMMIT:-unknown}
DEPLOYMENT_ID=${DEPLOYMENT_ID:-$(uuidgen)}

# ==============================================================================
# EXAMPLE VALUES - REPLACE WITH ACTUAL VALUES
# ==============================================================================

# This is a template file. Copy to .env.prod and replace all placeholder values
# with your actual production values before deployment.

# Security reminder:
# 1. Never commit production secrets to version control
# 2. Use strong, unique passwords and API keys
# 3. Regularly rotate secrets
# 4. Use proper secret management tools for large deployments
# 5. Enable database backups and test restore procedures